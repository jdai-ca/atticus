{
  "name": "atticus",
  "version": "0.9.18",
  "description": "Atticus - In-House AI Counsel",
  "main": "dist-electron/main.js",
  "author": "John Kost",
  "license": "Apache-2.0 OR Commercial",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "validate:practices": "node scripts/validate-practices-clean.js",
    "validate:advisory": "node scripts/validate-advisory-clean.js",
    "validate:providers": "node scripts/validate-providers-clean.js",
    "validate:analysis": "node scripts/validate-analysis-clean.js",
    "validate:all": "npm run validate:practices && npm run validate:advisory && npm run validate:providers && npm run validate:analysis",
    "ediscovery": "tsx scripts/eDiscovery.ts",
    "ediscovery:export": "tsx scripts/eDiscovery.ts --export",
    "predev": "npm run validate:all",
    "prebuild": "npm run validate:all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/genai": "^1.0.0",
    "@mistralai/mistralai": "^1.10.0",
    "@xmldom/xmldom": "^0.8.11",
    "ajv": "^6.12.6",
    "cohere-ai": "^7.20.0",
    "csv-parse": "^6.1.0",
    "dompurify": "^3.0.8",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.0",
    "jspdf": "^3.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.303.0",
    "mailparser": "^3.9.1",
    "mammoth": "^1.11.0",
    "marked": "^11.2.0",
    "officegen": "^0.6.5",
    "pdfjs-dist": "^5.4.449",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rtf-parser": "^1.3.3",
    "sharp": "^0.34.5",
    "sheetjs-style": "^0.15.8",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.6.2",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^38.2.2",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^7.1.10",
    "vite-plugin-electron": "^0.28.1",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ca.jdai.atticus",
    "productName": "Atticus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/**/*.map"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "dist/config/**/*",
      "node_modules/@google/genai/**/*",
      "node_modules/@mistralai/mistralai/**/*",
      "node_modules/@anthropic-ai/sdk/**/*",
      "node_modules/cohere-ai/**/*",
      "node_modules/google-auth-library/**/*",
      "node_modules/zod/**/*",
      "node_modules/@aws-crypto/**/*",
      "node_modules/@aws-sdk/**/*",
      "node_modules/@smithy/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon/icon.png"
    }
  }
}
